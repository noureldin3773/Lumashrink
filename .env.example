# Hosted checkout URL from Lemon Squeezy, Paddle, Gumroad, Stripe Payment Links, or another merchant.
LUMASHRINK_CHECKOUT_URL=https://checkout.example.com/lumashrink-pro

# Fulfillment/download URL for the signed and notarized macOS build.
LUMASHRINK_DOWNLOAD_URL=https://downloads.example.com/LumaShrink-macOS.zip

# Free web-trial limits.
LUMASHRINK_FREE_FILE_LIMIT=3
LUMASHRINK_MAX_UPLOAD_MB=50
LUMASHRINK_SESSION_RATE_LIMIT=12
LUMASHRINK_UPLOAD_RATE_LIMIT=36
LUMASHRINK_HOST=127.0.0.1
LUMASHRINK_PORT=8000
LUMASHRINK_RELOAD=0

# Public macOS release. The identity must exist in the login keychain.
LUMASHRINK_SIGNING_IDENTITY="Developer ID Application: Your Company (TEAMID)"
LUMASHRINK_NOTARY_PROFILE=LumaShrink
